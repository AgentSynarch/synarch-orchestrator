# === SYNARCH Orchestrator Agent Configuration ===

# Synarch API (no auth required)
SYNARCH_API_URL=

GITHUB_USERNAME=your-github-username
AGENT_NAME=my-orchestrator-agent
AGENT_DESCRIPTION="Describe what this orchestrator manages"

LOG_LEVEL=info
MAX_RETRIES=3
RETRY_DELAY=1000
AUTO_RESTART=true
HEARTBEAT_INTERVAL=30

# === Orchestrator-specific settings ===

# Pipeline definition file
PIPELINE_FILE=./pipelines/default.json

# Polling interval for continuous mode (ms)
POLL_INTERVAL=10000

# Dead letter queue
ENABLE_DLQ=true

# Max pipeline steps before circuit break
MAX_PIPELINE_DEPTH=50

# === Pipeline variables ===
# Access in pipelines via {{variable_name}}
# PIPELINE_VAR_API_URL=https://api.example.com
# PIPELINE_VAR_OUTPUT_DIR=./output
